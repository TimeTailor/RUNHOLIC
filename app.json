{
  "expo": {
    "name": "RUNHOLIC",
    "slug": "runholic",
    "scheme": "runholic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "starbion",
    "android": {
      "package": "com.starbion.runholic",
      "versionCode": 2,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#030b1f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2dXQG6XRmYoUhN-cd0tLTARiwMNQKwJ0"
        }
      }
    },
    "ios": {
      "bundleIdentifier": "com.starbion.runholic",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "러닝 기록과 지도 기능을 위해 위치 권한이 필요합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "화면이 꺼져도 러닝 기록을 계속하기 위해 항상 위치 권한이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "./plugins/withRunholicForegroundService",

      [
        "expo-location",
        {
          "locationWhenInUsePermission": "러닝 기록과 지도 기능을 위해 위치 권한이 필요합니다.",
          "locationAlwaysAndWhenInUsePermission": "화면이 꺼져도 러닝 기록을 계속하기 위해 항상 위치 권한이 필요합니다.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],

      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9213010752576483~1487110167",
          "iosAppId": "ca-app-pub-9213010752576483~3427499911"
        }
      ],

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#030b1f",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "러닝 인증 이미지를 저장하기 위해 사진 접근 권한이 필요합니다.",
          "savePhotosPermission": "러닝 인증 이미지를 갤러리에 저장하기 위해 사진 저장 권한이 필요합니다.",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "baace5a0-6564-4dda-8879-4f7e721b62a7"
      }
    }
  }
}
